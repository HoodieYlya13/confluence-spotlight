{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Confluence Spotlight",
  "version": "0.1.6",
  "identifier": "dev.hoodieylya13.confluence-spotlight",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Confluence Spotlight",
        "width": 700,
        "height": 480,
        "minWidth": 700,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": true,
        "visible": false,
        "center": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["confluence-spotlight"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/HoodieYlya13/confluence-spotlight/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlFNkYzODk5Q0Q0ODcyM0QKUldROWNrak5tVGh2bnVrVUhXZFpMNnVidVV3S1JpYWNTeWg4SUFiTi9XbVJ3OUtOa0tUMG5STGoK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
