TAURI_SIGNING_PRIVATE_KEY=demo
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=demo
MCP_SERVER_URL=https://hoodieylya13-mcp-confluence-documentation-rag.hf.space
SPOTLIGHT_HOTKEY=CmdOrCtrl+Shift+Space

# Sign-in goes through the OIDC identity provider (access + refresh tokens, role
# inside the access token). SSO_CLIENT_ID is this app's PUBLIC OIDC client_id
# (PKCE, redirect confluence-spotlight://auth).
SSO_ISSUER=https://auth.hy13dev.com
SSO_CLIENT_ID=confluence-spotlight-gjOtqPBt

# Read only in dev builds (`cargo run --example probe` and the in-app "Dev sign-in",
# since custom-scheme deep links can't round-trip under `tauri dev` on macOS).
# A released build never reads these — it obtains its token via the OIDC sign-in.
MCP_TOKEN_JUNIOR_OP=DEMO_JUNIOR
MCP_TOKEN_ATS_CORE_LEAD=DEMO_LEAD
